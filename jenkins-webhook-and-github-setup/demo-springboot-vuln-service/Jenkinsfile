pipeline {
  agent any

  environment {
    APP_REPO = '/workspace/demo-springboot-vuln-service'
    IMAGE_NAME = 'local/demo-springboot-vuln-service'
    CONTAINER_NAME = 'demo-springboot-vuln-service'
    HOST_PORT = '8082'
    DOCKER_BIN = 'docker'
    TRIVY_IMAGE = 'aquasec/trivy:0.57.1'
    RUN_VULNERABILITY_ANALYSIS = 'true'
    TRIVY_CACHE_VOLUME = 'trivy-cache'
    VULN_ANALYSIS_SEVERITY = 'HIGH,CRITICAL'
    VULN_ANALYSIS_TIMEOUT = '2m'
    LOG_DIR = 'pipeline-logs'
    WEBHOOK_URL = 'http://host.docker.internal:8000/api/v1/webhooks/jenkins/failure'
    WEBHOOK_SECRET = 'change-me'
    SOURCE_BRANCH = 'main'
    REPO_NAME = 'nishathmnha/demo-springboot-vuln-service'
  }

  stages {
    stage('Show Environment') {
      steps {
        sh '''
          mkdir -p "${LOG_DIR}"
          rm -f "${LOG_DIR}"/*.log

          (
            echo "PATH=$PATH"
            command -v ${DOCKER_BIN}
            ${DOCKER_BIN} version
            test -f ${APP_REPO}/pom.xml
            test -f ${APP_REPO}/Dockerfile
          ) > "${LOG_DIR}/show-environment.log" 2>&1

          status=$?
          cat "${LOG_DIR}/show-environment.log"
          exit $status
        '''
      }
    }

    stage('Build Spring Boot Image') {
      steps {
        sh '''
          (
            ${DOCKER_BIN} build \
              -t ${IMAGE_NAME}:${BUILD_NUMBER} \
              -t ${IMAGE_NAME}:latest \
              ${APP_REPO}
          ) > "${LOG_DIR}/build-image.log" 2>&1

          status=$?
          cat "${LOG_DIR}/build-image.log"
          exit $status
        '''
      }
    }

    stage('Deploy Container') {
      steps {
        sh '''
          (
            ${DOCKER_BIN} rm -f ${CONTAINER_NAME} || true
            ${DOCKER_BIN} run -d \
              --name ${CONTAINER_NAME} \
              -p ${HOST_PORT}:8080 \
              ${IMAGE_NAME}:${BUILD_NUMBER}
          ) > "${LOG_DIR}/deploy-container.log" 2>&1

          status=$?
          cat "${LOG_DIR}/deploy-container.log"
          exit $status
        '''
      }
    }

    stage('Verify Deployment') {
      steps {
        sh '''
          (
            sleep 8
            curl --fail http://host.docker.internal:${HOST_PORT}/health
          ) > "${LOG_DIR}/verify-deployment.log" 2>&1

          status=$?
          cat "${LOG_DIR}/verify-deployment.log"
          exit $status
        '''
      }
    }

    stage('Lightweight Vulnerability Analysis') {
      when {
        expression { env.RUN_VULNERABILITY_ANALYSIS == 'true' }
      }
      steps {
        sh '''
          (
            set +e
            ${DOCKER_BIN} run --rm \
              -v ${TRIVY_CACHE_VOLUME}:/tmp/trivy-cache \
              -v /var/run/docker.sock:/var/run/docker.sock \
              ${TRIVY_IMAGE} image \
              --cache-dir /tmp/trivy-cache \
              --scanners vuln \
              --severity ${VULN_ANALYSIS_SEVERITY} \
              --ignore-unfixed \
              --format table \
              --no-progress \
              --timeout ${VULN_ANALYSIS_TIMEOUT} \
              ${IMAGE_NAME}:${BUILD_NUMBER}

            trivy_status=$?
            echo
            if [ $trivy_status -eq 0 ]; then
              echo "Vulnerability analysis completed."
            else
              echo "Vulnerability analysis ended with a non-fatal scanner error (exit ${trivy_status})."
            fi
          ) > "${LOG_DIR}/scan-image.log" 2>&1

          cat "${LOG_DIR}/scan-image.log"
          exit 0
        '''
      }
    }
  }

  post {
    success {
      echo "Deployment succeeded. Open http://localhost:8082/health on your machine."
      echo "Lightweight vulnerability analysis ran without blocking the local deployment."
    }
    failure {
      sh '''
        mkdir -p "${LOG_DIR}"
        if command -v ${DOCKER_BIN} >/dev/null 2>&1; then
          ${DOCKER_BIN} logs ${CONTAINER_NAME} > "${LOG_DIR}/container.log" 2>&1 || true
        fi
      '''
      script {
        def logFiles = [
          'show-environment.log',
          'build-image.log',
          'scan-image.log',
          'deploy-container.log',
          'verify-deployment.log',
          'container.log',
        ]

        def consoleSections = []
        logFiles.each { logFile ->
          def path = "${env.LOG_DIR}/${logFile}"
          if (fileExists(path)) {
            consoleSections << "===== ${logFile} =====\n${readFile(path)}"
          }
        }

        def consoleText = consoleSections.join('\n\n')
        int maxConsoleChars = 60000
        if (consoleText.length() > maxConsoleChars) {
          consoleText = "[truncated to last ${maxConsoleChars} characters]\n" +
            consoleText.substring(consoleText.length() - maxConsoleChars)
        }

        def payload = [
          job_name: env.JOB_NAME,
          build_number: env.BUILD_NUMBER.toInteger(),
          build_url: env.BUILD_URL,
          branch: env.SOURCE_BRANCH,
          repo: env.REPO_NAME,
          status: 'FAILED',
          console_text: consoleText,
        ]

        writeFile(
          file: 'webhook_payload.json',
          text: groovy.json.JsonOutput.prettyPrint(groovy.json.JsonOutput.toJson(payload)),
        )
      }
      sh '''
        curl --fail --show-error -X POST "${WEBHOOK_URL}" \
          -H "Content-Type: application/json" \
          -H "X-Webhook-Secret: ${WEBHOOK_SECRET}" \
          --data @webhook_payload.json
      '''
      echo 'Build failed. If the failure is in Scan Image, that is expected for the vulnerable demo.'
    }
  }
}
